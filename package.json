{
  "name": "linking-scrapbox",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "linking-scrapbox": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc && printf '#!/usr/bin/env node\n' | cat - dist/index.js > dist/index.with-shebang.js && mv dist/index.with-shebang.js dist/index.js",
    "start": "node --env-file=.env dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@google/genai": "^1.0.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
